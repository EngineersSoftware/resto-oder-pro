# =====================================================
#  GourmetExpress — .gitignore
# =====================================================

# ── Dependencias ──────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Variables de entorno (NUNCA subir al repo) ────────
.env
.env.local
.env.*.local
.env.production

# ── Logs ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed

# ── Build / dist ──────────────────────────────────────
dist/
build/
out/

# ── Sistema operativo ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editores e IDEs ───────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing / cobertura ───────────────────────────────
coverage/
.nyc_output/

# ── Temporales ────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.cache
